{
  "name": "grafana-pathfinder-app",
  "version": "2.10.0",
  "bin": {
    "pathfinder-cli": "./dist/cli/cli/index.js",
    "pathfinder-mcp": "./dist/cli/cli/mcp/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "copy-static": "node scripts/copy-static.js",
    "docs:sync-terms": "node scripts/sync-terms-and-conditions.js",
    "docs:sync-terms:check": "node scripts/sync-terms-and-conditions.js --check",
    "build:backend": "npm run copy-static && mage -v build:linux",
    "build:backend:linux-arm64": "npm run copy-static && mage -v build:linuxARM64",
    "build:backend:darwin": "npm run copy-static && mage -v build:darwin",
    "build:backend:darwin-arm64": "npm run copy-static && mage -v build:darwinARM64",
    "build:backend:windows": "npm run copy-static && mage -v build:windows",
    "build:all": "npm run build && npm run build:backend && npm run build:backend:linux-arm64",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "dev:backend": "mage -v build:linux && npm run dev",
    "peerjs-server": "node scripts/peerjs-server.js",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:watch": "jest --coverage --watch",
    "test:go": "mage -v test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "lint:go": "mage -v lint",
    "e2e": "playwright test",
    "server": "npm run build:all && docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "prettier": "prettier -v && prettier --config .prettierrc.js --check '**/*.{ts,tsx,js,json,yaml,md}' --write",
    "prettier-test": "prettier -v && prettier --config .prettierrc.js --check '**/*.{ts,tsx,js,json,yaml,md}'",
    "i18n-extract": "i18next --config src/locales/i18next-parser.config.js",
    "build:cli": "tsc -p tsconfig.cli.json",
    "validate": "node dist/cli/cli/index.js validate --bundled",
    "validate:strict": "node dist/cli/cli/index.js validate --bundled --strict",
    "validate:packages": "node dist/cli/cli/index.js validate --packages src/bundled-interactives",
    "repository:build": "node dist/cli/cli/index.js build-repository src/bundled-interactives -o src/bundled-interactives/repository.json",
    "repository:check": "node dist/cli/cli/index.js build-repository src/bundled-interactives -o /tmp/repository-check.json && diff -q src/bundled-interactives/repository.json /tmp/repository-check.json",
    "schema:export": "node dist/cli/cli/index.js schema --all",
    "check": "npm run typecheck && npm run lint && npm run prettier-test && npm run docs:sync-terms:check && npm run lint:go && npm run test:go && npm run test:ci",
    "prepare": "husky"
  },
  "author": "Grafanalabs",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/faro-webpack-plugin": "^0.11.0",
    "@grafana/plugin-e2e": "^3.6.1",
    "@grafana/tsconfig": "^2.0.1",
    "@jest/test-sequencer": "^30.2.0",
    "@playwright/test": "^1.56.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.1",
    "@swc/helpers": "^0.5.17",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/testing-library__jest-dom": "5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "baseline-browser-mapping": "^2.9.11",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.1.12",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-webpack-plugin": "^5.0.2",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "peer": "^1.0.2",
    "prettier": "3.8.3",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "semver": "^7.7.3",
    "style-loader": "4.0.0",
    "swc-loader": "^0.2.6",
    "terser-webpack-plugin": "^5.3.14",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/css": "11.13.5",
    "@grafana/assistant": "^0.1.19",
    "@grafana/data": "^12.4.3",
    "@grafana/faro-react": "^2.0.2",
    "@grafana/faro-web-tracing": "^2.0.2",
    "@grafana/i18n": "^12.4.3",
    "@grafana/scenes": "^7.4.2",
    "@grafana/schema": "^12.4.3",
    "@grafana/ui": "^12.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openfeature/ofrep-web-provider": "^0.3.5",
    "@openfeature/react-sdk": "^1.0.0",
    "@openfeature/web-sdk": "^1.7.2",
    "@tiptap/extension-link": "^3.10.4",
    "@tiptap/markdown": "^3.15.3",
    "@tiptap/pm": "^3.10.4",
    "@tiptap/react": "^3.10.4",
    "@tiptap/starter-kit": "^3.10.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^14.0.0",
    "dompurify": "^3.3.2",
    "idb": "^8.0.3",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "peerjs": "^1.5.5",
    "prismjs": "1.30.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.28.0",
    "rxjs": "7.8.2",
    "zod": "^4.1.13"
  },
  "overrides": {
    "dompurify": "^3.3.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,yaml,md}": "prettier --config .prettierrc.js --write"
  },
  "packageManager": "npm@11.13.0"
}
