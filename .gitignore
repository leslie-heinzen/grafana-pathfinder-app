# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

node_modules/

# yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# Compiled binary addons (https://nodejs.org/api/addons.html)
dist/
artifacts/
work/
ci/

# e2e test directories
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Editor
.idea

.eslintcache
.DS_Store
.hippo
temp/
plans/

# Cursor local prompt context, so as not to pollute repo
.cursor/local

# Prevent generated JS artifacts in src from being committed
src/**/*.js
src/**/*.js.map

# Generated static files for Go embed (produced by scripts/copy-static.js)
# pkg/plugin/static/ is intentionally committed — generated by scripts/copy-static.js and required for go:embed

# Personal manual-deploy script for the MCP server. Hardcodes a project ID
# and is intentionally not part of the repo — until P4 picks the official
# hosting model, this is a one-developer convenience, not a contract.
deploy-mcp.sh
